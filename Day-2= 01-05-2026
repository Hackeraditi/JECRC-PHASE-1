//Program-3 --nested if-else condition
//to verify user's age whether eligible for vote or not?
#include <iostream>
using namespace std;

int main() {
    int age;
    cin >> age;
    
    // if condition 
    if(age >= 18) {
        if (age >= 100) {
            // logic 
            cout << "Eligible For vote and Senior Citizen" << endl;
        } else {
            // logic 
            cout << "Eligible For vote" << endl;
        }
    } else {
        if(age < 0) {
            cout << "Invalid age" << endl;
        } else {
            cout << "Not Eligible For vote" << endl;
        }
    }
    return 0;
}

//Problem-4 --ternary operator
// find the greater number among 2

#include <iostream>
using namespace std;
int main() {
    int a, b;
    int max_number;

    cin >> a >> b;
    max_number = (a > b) ? a : b; //Condition**: Is a greater than b? If TRUE**: Use value of a, If FALSE**: Use value of b
    cout << "Greater number is: " << max_number << endl;
    return 0;   
}



//program-5  --continue statement
//print 1 to N and avoid those number which are divisible by 3
#include <iostream>
using namespace std;
int main() {
    int n;
    cin >> n;

    for(int i = 1; i <= n; i++) {
        if(i % 3 == 0) {
            continue;
        }
            cout << i << " ";
        }
        cout<<"\n";
    
    
    return 0;
}

//program-6 -- break statement
//We have to add numbers until we get a negative number
#include <iostream>
using namespace std;
int main() {
    int n;
   int sum=0;
    while(true){
        cin >> n;
        if(n < 0){
            break;
        }
        sum += n;
    }
    cout << "The total sum is:"<<sum << endl;
    return 0;
}


