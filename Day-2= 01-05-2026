//program-8 -- switch statement
//customer support IVR system
//1-- for support
//2-- for billing
//3-- technical issues
//4-- talk to agent

//customer support IVR system
//1-- for support
//2-- for billing
//3-- technical issues
//4-- talk to agent
#include <iostream>
using namespace std;
int main() {
    int choice;
    cout << "Welcome to our customer support IVR system!" << endl;
    cout << "Please select an option:" << endl;
    cout << "1. Support" << endl;
    cout << "2. Billing" << endl;
    cout << "3. Technical Issues" << endl;
    cout << "4. Talk to an Agent" << endl;
    cin >> choice;

    switch (choice) {
        case 1:
            cout << "You have selected Support. Please wait while we connect you to a support representative." << endl;
            break;
        case 2:
            cout << "You have selected Billing. Please wait while we connect you to a billing representative." << endl;
            break;
        case 3:
            cout << "You have selected Technical Issues. Please wait while we connect you to a technical support representative." << endl;
            break;
        case 4:
            cout << "You have selected Talk to an Agent. Please wait while we connect you to an agent." << endl;
            break;
        default:
            cout << "Invalid option selected. Please try again." << endl;
            break;
    }

    return 0;
}
