// Problem 1 -- If condition 
// to verify user's age wether eligible for vote or not ?
#include <iostream>
using namespace std;

int main() {
    int age;
    cin >> age;
    // if condition 
    if(age >= 18) {
        // logic 
        cout << "Eligible For vote";
    }
    return 0;
}

// Problem 2 -- If - else condition 
// to verify user's age wether eligible for vote or not ?
#include <iostream>
using namespace std;

int main() {
    int age;
    cin >> age;
    // if condition 
    if(age >= 18) {
        // logic 
        cout << "Eligible For vote";
    } else {
        // logic 
        cout << "Not Eligible For vote";
    }
    return 0;
}

//Program-3 --nested if-else condition
//to verify user's age whether eligible for vote or not?
#include <iostream>
using namespace std;

int main() {
    int age;
    cin >> age;
    
    // if condition 
    if(age >= 18) {
        if (age >= 100) {
            // logic 
            cout << "Eligible For vote and Senior Citizen" << endl;
        } else {
            // logic 
            cout << "Eligible For vote" << endl;
        }
    } else {
        if(age < 0) {
            cout << "Invalid age" << endl;
        } else {
            cout << "Not Eligible For vote" << endl;
        }
    }
    return 0;
}

//Problem-4 --ternary operator
// find the greater number among 2

#include <iostream>
using namespace std;
int main() {
    int a, b;
    int max_number;

    cin >> a >> b;
    max_number = (a > b) ? a : b; //Condition**: Is a greater than b? If TRUE**: Use value of a, If FALSE**: Use value of b
    cout << "Greater number is: " << max_number << endl;
    return 0;   
}
