//Single inheritance
#include <iostream>
using namespace std;
 int main(){
    class A{
        public:
        void start(){
            cout<<"This is class A start"<<endl;
        }
    };
    class B:public A{
        public:
        void drive(){
            cout<<"This is class B become drive"<<endl;
        }
    };
    B obj;
    obj.start();
    obj.drive();
    return 0;
 }

