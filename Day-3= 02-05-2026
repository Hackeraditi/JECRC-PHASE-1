//program 2 -- reverse string
//print 10 to 1 using loop
#include <iostream>
using namespace std;

int main() {
for(int i=10; i>=1; i--) {
cout << i<< "";
    }

    return 0;
}

//Problem 3 -- while loop statement for loop n to 1
#include <iostream>
using namespace std;
int main()
{
    int i=1;
    int n;
    cin >> n;
    while (i<=n) {
        cout << i << " ";
        i++;
    }

    return 0;
}

// Problem 4 
// Print 10 to 1 using a while loop 

#include <iostream>
using namespace std;

int main() {
    int i = 10;
    while (i >= 1) {
        cout << i << " ";
        i--;
    }
    return 0;
}

